{
  "name": "git-vibed",
  "version": "0.1.1",
  "private": true,
  "description": "Experimental 100% vibe-coded Git GUI client",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder --publish never",
    "build:unpack": "tsc -p tsconfig.node.json && vite build && electron-builder --dir",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --project=unit",
    "test:browser": "vitest run --project=browser"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.100.1",
    "chokidar": "^5.0.0",
    "highlight.js": "^11.11.1",
    "monaco-editor": "^0.55.1",
    "node-diff3": "^3.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "simple-git": "^3.36.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query-devtools": "^5.100.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.2",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.0",
    "vite": "^8.0.9",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.gitvibed.app",
    "productName": "Git Vibed",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "public/logo.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "public/logo.png",
      "maintainer": "StyleShit <32631382+StyleShit@users.noreply.github.com>"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
