{
  "name": "git-gui",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform Git GUI client built with Electron + React",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "build:unpack": "tsc -p tsconfig.node.json && vite build && electron-builder --dir",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "chokidar": "^5.0.0",
    "diff2html": "^3.4.56",
    "monaco-editor": "^0.55.1",
    "node-diff3": "^3.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-window": "^2.2.7",
    "simple-git": "^3.36.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.0",
    "vite": "^8.0.9",
    "vite-plugin-electron": "^0.29.1"
  },
  "build": {
    "appId": "com.gitgui.app",
    "productName": "Git GUI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
